{
  "name": "hybrid-ai-assistant",
  "displayName": "hybrid-ai-assistant",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai",
          "title": "AI",
          "icon": "$(sparkle)"
        }
      ]
    },
    "views": {
      "ai": [
        {
          "id": "ai.chat",
          "name": "AI Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "hybrid-ai-assistant.setApiKey",
        "title": "AI Assistant: Set API Key"
      },
      {
        "command": "hybrid-ai-assistant.deleteApiKey",
        "title": "AI Assistant: Delete API Key"
      },
      {
        "command": "hybrid-ai-assistant.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "dotenv": "^17.4.2"
  }
}